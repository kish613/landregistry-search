{
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "app/static/**",
      "use": "@vercel/static"
    },
    {
      "src": "docs/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/.well-known/security.txt",
      "dest": "app/static/.well-known/security.txt"
    },
    {
      "src": "/static/(.*)",
      "dest": "app/static/$1"
    },
    {
      "src": "/docs",
      "status": 308,
      "headers": { "Location": "/docs/" }
    },
    {
      "src": "/docs/",
      "dest": "/docs/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/docs/([^.]+)",
      "dest": "/docs/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "app/main.py"
    }
  ]
}
